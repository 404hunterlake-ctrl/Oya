# ============================================
# SUPABASE CONFIGURATION
# ============================================

# Get these from: https://supabase.com/dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..." # For server-only ops

# ============================================
# APP CONFIGURATION
# ============================================

APP_URL="http://localhost:3000"
NODE_ENV="development"

# ============================================
# GEMINI API (Optional)
# ============================================

GEMINI_API_KEY=""

# ============================================
# PAYMENT CONFIGURATION (Paystack)
# ============================================

# Enable/disable payment processing
NEXT_PUBLIC_PAYMENT_ENABLED="true"

# Paystack API Keys - Get from https://dashboard.paystack.com/#/settings/developer
# NEVER commit these - use Vercel environment variables
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY="pk_test_"
PAYSTACK_SECRET_KEY="sk_test_"
PAYSTACK_WEBHOOK_SECRET=""

# Payment settings
NEXT_PUBLIC_MIN_PAYMENT=500        # Minimum payment in Naira
NEXT_PUBLIC_MAX_PAYMENT=500000     # Maximum payment in Naira

# ============================================
# SECURITY
# ============================================

# Enable rate limiting
NEXT_PUBLIC_RATE_LIMIT_ENABLED="true"

# ============================================
# LOGGING
# ============================================

NEXT_PUBLIC_LOG_LEVEL="info" # debug, info, warn, error
